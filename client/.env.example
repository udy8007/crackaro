# Leave empty in local dev (Vite proxies /api → localhost:5000)
# Leave empty on Vercel too (same origin: https://www.crackaro.in/api)
# Set this only if the API is on another origin
VITE_API_URL=

# Public site origin for SEO (canonical, OG). Defaults to https://www.crackaro.in
VITE_SITE_URL=https://www.crackaro.in
